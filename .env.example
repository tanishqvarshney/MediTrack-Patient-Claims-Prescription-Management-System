# MediTrack Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Database
DB_PASSWORD=Dev@1234!

# Redis
REDIS_PASSWORD=redis_secret_change_me

# JWT (must be at least 32 characters)
JWT_SECRET=supersecret_CHANGE_THIS_in_production_min32chars!

# Deployment (used by GitHub Actions)
DEPLOY_HOST=your-server-ip
DEPLOY_USER=deploy
